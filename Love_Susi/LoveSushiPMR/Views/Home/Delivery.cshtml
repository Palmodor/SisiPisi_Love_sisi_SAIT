@{
    ViewData["Title"] = "Доставка и оплата";
}

<section class="delivery-section">
    <div class="container">
        <h1 class="page-title text-center">Доставка и оплата</h1>
        
        <div class="row">
            <div class="col-lg-6">
                <div class="delivery-info-block">
                    <h3><i class="bi bi-truck"></i> Условия доставки</h3>
                    <ul>
                        <li>Доставка работает ежедневно с 10:00 до 23:00</li>
                        <li>Бесплатная доставка при заказе от 1000 ₽</li>
                        <li>Среднее время доставки: 30-50 минут</li>
                        <li>Минимальная сумма заказа: 500 ₽</li>
                    </ul>
                    
                    <h4 class="mt-4">Зоны доставки</h4>
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Район</th>
                                <th>Стоимость</th>
                                <th>Время</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Центр города</td>
                                <td>Бесплатно</td>
                                <td>30-50 мин</td>
                            </tr>
                            <tr>
                                <td>Спутник</td>
                                <td>150 ₽</td>
                                <td>40-60 мин</td>
                            </tr>
                            <tr>
                                <td>Западный</td>
                                <td>100 ₽</td>
                                <td>35-55 мин</td>
                            </tr>
                            <tr>
                                <td>Северный</td>
                                <td>100 ₽</td>
                                <td>35-55 мин</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="payment-info-block">
                    <h3><i class="bi bi-credit-card"></i> Способы оплаты</h3>
                    <div class="payment-method">
                        <i class="bi bi-cash"></i>
                        <div>
                            <strong>Наличными</strong>
                            <p>Оплата курьеру при получении заказа</p>
                        </div>
                    </div>
                    <div class="payment-method">
                        <i class="bi bi-credit-card"></i>
                        <div>
                            <strong>Картой онлайн</strong>
                            <p>Оплата банковской картой на сайте</p>
                        </div>
                    </div>
                    <div class="payment-method">
                        <i class="bi bi-credit-card-2-front"></i>
                        <div>
                            <strong>Картой курьеру</strong>
                            <p>Оплата банковской картой при получении</p>
                        </div>
                    </div>
                    <div class="payment-method">
                        <i class="bi bi-gift"></i>
                        <div>
                            <strong>Бонусными баллами</strong>
                            <p>Накапливайте баллы и оплачивайте ими заказы</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>