@{
    ViewData["Title"] = "Контакты";
}

<section class="contacts-section">
    <div class="container">
        <h1 class="page-title text-center">Контакты</h1>
        
        <div class="row">
            <div class="col-lg-6">
                <div class="contact-info">
                    <h3>Свяжитесь с нами</h3>
                    <div class="contact-item">
                        <i class="bi bi-geo-alt"></i>
                        <div>
                            <strong>Адрес</strong>
                            <p>г. Тирасполь, ул. Ленина, 1</p>
                        </div>
                    </div>
                    <div class="contact-item">
                        <i class="bi bi-telephone"></i>
                        <div>
                            <strong>Телефон</strong>
                            <p><a href="tel:+37377712345">+373 (777) 12-345</a></p>
                        </div>
                    </div>
                    <div class="contact-item">
                        <i class="bi bi-envelope"></i>
                        <div>
                            <strong>Email</strong>
                            <p><a href="mailto:info@lovesushi.md">info@lovesushi.md</a></p>
                        </div>
                    </div>
                    <div class="contact-item">
                        <i class="bi bi-clock"></i>
                        <div>
                            <strong>Режим работы</strong>
                            <p>Ежедневно с 10:00 до 23:00</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="contact-map">
                    <div class="map-placeholder">
                        <i class="bi bi-map"></i>
                        <p>Карта проезда</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>