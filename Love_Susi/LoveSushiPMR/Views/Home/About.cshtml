@{
    ViewData["Title"] = "О нас";
}

<section class="about-section">
    <div class="container">
        <h1 class="page-title">О нас</h1>
        
        <div class="row align-items-center">
            <div class="col-lg-6">
                <div class="about-content">
                    <h2>LoveSushi PMR - вкусная доставка суши</h2>
                    <p>Мы - команда профессионалов, которые обожают японскую кухню и хотят дарить вам радость от каждого заказа.</p>
                    
                    <div class="about-features">
                        <div class="about-feature">
                            <i class="bi bi-check-circle-fill text-success"></i>
                            <span>Свежие продукты каждый день</span>
                        </div>
                        <div class="about-feature">
                            <i class="bi bi-check-circle-fill text-success"></i>
                            <span>Опытные повара</span>
                        </div>
                        <div class="about-feature">
                            <i class="bi bi-check-circle-fill text-success"></i>
                            <span>Быстрая доставка</span>
                        </div>
                        <div class="about-feature">
                            <i class="bi bi-check-circle-fill text-success"></i>
                            <span>Бонусная программа</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="about-image">
                    <div class="about-placeholder">🍣</div>
                </div>
            </div>
        </div>
    </div>
</section>