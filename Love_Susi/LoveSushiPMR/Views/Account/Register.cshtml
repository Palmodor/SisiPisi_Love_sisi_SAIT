@model RegisterViewModel

@{
    ViewData["Title"] = "Регистрация";
}

<section class="auth-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="auth-card">
                    <div class="auth-header">
                        <div class="auth-icon">🍣</div>
                        <h2>Создать аккаунт</h2>
                        <p>Регистрация займёт меньше минуты</p>
                    </div>
                    
                    <form asp-action="Register" method="post" novalidate id="registerForm">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        <div class="form-floating mb-3">
                            <input type="text" class="form-control" id="name" name="Name" placeholder="Ваше имя" required>
                            <label for="name"><i class="bi bi-person"></i> Ваше имя</label>
                            <span asp-validation-for="Name" class="text-danger d-block"></span>
                        </div>
                        
                        <div class="form-floating mb-3">
                            <input type="email" class="form-control" id="email" name="Email" placeholder="name@example.com" required>
                            <label for="email"><i class="bi bi-envelope"></i> Email</label>
                            <span asp-validation-for="Email" class="text-danger d-block"></span>
                        </div>
                        
                        <div class="form-floating mb-3">
                            <input type="tel" class="form-control" id="phone" name="Phone" placeholder="+373..." required>
                            <label for="phone"><i class="bi bi-telephone"></i> Телефон</label>
                            <span asp-validation-for="Phone" class="text-danger d-block"></span>
                        </div>
                        
                        <div class="form-floating mb-3">
                            <input type="password" class="form-control" id="password" name="Password" placeholder="Пароль" required minlength="6">
                            <label for="password"><i class="bi bi-lock"></i> Пароль (мин. 6 символов)</label>
                            <span asp-validation-for="Password" class="text-danger d-block"></span>
                        </div>
                        
                        <div class="form-floating mb-3">
                            <input type="password" class="form-control" id="confirmPassword" name="ConfirmPassword" placeholder="Подтвердите пароль" required>
                            <label for="confirmPassword"><i class="bi bi-lock-fill"></i> Подтвердите пароль</label>
                            <span asp-validation-for="ConfirmPassword" class="text-danger d-block"></span>
                        </div>

                        <div class="accordion mb-3" id="adminAccordion">
                            <div class="accordion-item">
                                <h2 class="accordion-header">
                                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#adminCollapse">
                                        <i class="bi bi-shield-lock me-2"></i> Регистрация администратора
                                    </button>
                                </h2>
                                <div id="adminCollapse" class="accordion-collapse collapse" data-bs-parent="#adminAccordion">
                                    <div class="accordion-body">
                                        <div class="form-floating">
                                            <input type="password" class="form-control" id="adminCode" name="AdminCode" placeholder="Код администратора">
                                            <label for="adminCode">Код администратора</label>
                                            <small class="text-muted">Введите секретный код для получения прав администратора</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <button type="submit" class="btn btn-primary w-100 btn-lg" id="registerBtn">Зарегистрироваться</button>
                    </form>
                    
                    <div class="auth-footer">
                        <p>Уже есть аккаунт? <a asp-action="Login">Войти</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
