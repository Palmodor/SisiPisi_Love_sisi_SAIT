 @model List<Category>
@{
    ViewData["Title"] = "Категории";
}

<section class="admin-section">
    <div class="container-fluid">
        <div class="admin-header">
            <div>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-2">
                    <i class="bi bi-arrow-left"></i> Назад
                </a>
                <h1><i class="bi bi-folder"></i> Категории</h1>
            </div>
            <a asp-action="CreateCategory" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Добавить категорию
            </a>
        </div>

        <div class="admin-card">
            <div class="table-responsive">
                <table class="table admin-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Иконка</th>
                            <th>Название</th>
                            <th>Порядок</th>
                            <th>Блюд</th>
                            <th>Статус</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var category in Model)
                        {
                            <tr>
                                <td>@category.Id</td>
                                <td style="font-size: 1.5rem;">@category.IconUrl</td>
                                <td><strong>@category.Name</strong></td>
                                <td>@category.SortOrder</td>
                                <td>@category.Dishes.Count</td>
                                <td>
                                    @if (category.IsActive)
                                    {
                                        <span class="badge bg-success">Активна</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Неактивна</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group">
                                        <a asp-action="EditCategory" asp-route-id="@category.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="DeleteCategory" asp-route-id="@category.Id" method="post" 
                                              onsubmit="return confirm('Удалить категорию @category.Name?');" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>