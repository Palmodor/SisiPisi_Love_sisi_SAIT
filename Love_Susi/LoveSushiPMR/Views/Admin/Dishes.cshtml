 @model List<DishViewModel>
@{
    ViewData["Title"] = "Управление блюдами";
}

<section class="admin-section">
    <div class="container-fluid">
        <div class="admin-header">
            <div>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-2">
                    <i class="bi bi-arrow-left"></i> Назад
                </a>
                <h1><i class="bi bi-menu-button-wide"></i> Управление блюдами</h1>
            </div>
            <a asp-action="CreateDish" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Добавить блюдо
            </a>
        </div>

        <div class="admin-card">
            <div class="table-responsive">
                <table class="table admin-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Изображение</th>
                            <th>Название</th>
                            <th>Категория</th>
                            <th>Вес</th>
                            <th>Цена</th>
                            <th>Статус</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var dish in Model)
                        {
                            <tr>
                                <td>@dish.Id</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(dish.ImageUrl))
                                    {
                                        <img src="@dish.ImageUrl" alt="@dish.Name" class="dish-thumb" />
                                    }
                                    else
                                    {
                                        <span class="dish-thumb-placeholder">🍣</span>
                                    }
                                </td>
                                <td>
                                    <strong>@dish.Name</strong>
                                    @if (dish.IsPopular)
                                    {
                                        <span class="badge bg-danger">ХИТ</span>
                                    }
                                    @if (dish.IsNew)
                                    {
                                        <span class="badge bg-success">NEW</span>
                                    }
                                </td>
                                <td>@dish.CategoryName</td>
                                <td>@dish.WeightGrams г</td>
                                <td>@dish.Price.ToString("N0") ₽</td>
                                <td>
                                    @if (dish.IsAvailable)
                                    {
                                        <span class="badge bg-success">Активно</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Неактивно</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group">
                                        <a asp-action="EditDish" asp-route-id="@dish.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="DeleteDish" asp-route-id="@dish.Id" method="post" 
                                              onsubmit="return confirm('Удалить блюдо @dish.Name?');" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>