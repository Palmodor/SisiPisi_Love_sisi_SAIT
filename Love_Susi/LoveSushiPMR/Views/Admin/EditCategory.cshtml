@model Category
@{
    ViewData["Title"] = "Редактирование категории";
}

<section class="admin-section">
    <div class="container">
        <div class="admin-header">
            <div>
                <a asp-action="Categories" class="btn btn-outline-secondary btn-sm mb-2">
                    <i class="bi bi-arrow-left"></i> Назад к списку
                </a>
                <h1><i class="bi bi-pencil"></i> Редактирование категории</h1>
            </div>
        </div>

        <div class="row justify-content-center">
            <div class="col-md-8">
        <div class="admin-card">
            <form asp-action="EditCategory" method="post">
                <input type="hidden" asp-for="Id" />
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">Название</label>
                            <input type="text" asp-for="Name" class="form-control" required />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">Иконка (эмодзи)</label>
                            <input type="text" asp-for="IconUrl" class="form-control" placeholder="🍣" />
                            <small class="text-muted">Например: 🍣 🍕 🍜</small>
                        </div>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">Порядок сортировки</label>
                            <input type="number" asp-for="SortOrder" class="form-control" min="0" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-check mt-4">
                            <input type="checkbox" asp-for="IsActive" class="form-check-input" />
                            <label class="form-check-label">Активна</label>
                        </div>
                    </div>
                </div>
                
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg"></i> Сохранить изменения
                    </button>
                    <a asp-action="Categories" class="btn btn-outline-secondary">Отмена</a>
                </div>
            </form>
        </div>
            </div>
        </div>
    </div>
</section>