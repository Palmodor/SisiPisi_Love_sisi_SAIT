@model DishEditViewModel
@{
    ViewData["Title"] = "Редактирование блюда";
}

<section class="admin-section">
    <div class="container">
        <div class="admin-header">
            <div>
                <a asp-action="Dishes" class="btn btn-outline-secondary btn-sm mb-2">
                    <i class="bi bi-arrow-left"></i> Назад к списку
                </a>
                <h1><i class="bi bi-pencil"></i> Редактирование блюда</h1>
            </div>
        </div>

        <div class="row justify-content-center">
            <div class="col-md-10">
        <div class="admin-card">
            <form asp-action="EditDish" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Id" />
                
                <div class="row">
                    <div class="col-md-8">
                        <div class="mb-3">
                            <label class="form-label">Название</label>
                            <input type="text" asp-for="Name" class="form-control" required />
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Описание</label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Цена (₽)</label>
                                <input type="number" asp-for="Price" class="form-control" step="0.01" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Вес (г)</label>
                                <input type="number" asp-for="WeightGrams" class="form-control" required />
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Категория</label>
                            <select asp-for="CategoryId" class="form-select" required>
                                @foreach (var cat in Model.Categories)
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                    
                    <div class="col-md-4">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="mb-3">
                                <label class="form-label">Текущее изображение</label>
                                <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded" style="max-height: 200px;" />
                            </div>
                        }
                        
                        <div class="mb-3">
                            <label class="form-label">Новое изображение</label>
                            <input type="file" asp-for="ImageFile" class="form-control" accept="image/*" />
                            <input type="hidden" asp-for="ImageUrl" />
                        </div>
                        
                        <div class="form-check mb-3">
                            <input type="checkbox" asp-for="IsAvailable" class="form-check-input" />
                            <label class="form-check-label">Доступно для заказа</label>
                        </div>
                        
                        <div class="form-check mb-3">
                            <input type="checkbox" asp-for="IsPopular" class="form-check-input" />
                            <label class="form-check-label">Популярное (ХИТ)</label>
                        </div>
                        
                        <div class="form-check mb-3">
                            <input type="checkbox" asp-for="IsNew" class="form-check-input" />
                            <label class="form-check-label">Новинка (NEW)</label>
                        </div>
                    </div>
                </div>
                
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg"></i> Сохранить изменения
                    </button>
                    <a asp-action="Dishes" class="btn btn-outline-secondary">Отмена</a>
                </div>
            </form>
        </div>
            </div>
        </div>
    </div>
</section>