@model LoveSushiPMR.Models.ViewModels.CourierEditViewModel

@{
    ViewData["Title"] = "Редактировать курьера";
}

<section class="admin-section">
    <div class="container-fluid">
        <div class="admin-header">
            <div>
                <a asp-action="Couriers" class="btn btn-outline-secondary btn-sm mb-2">
                    <i class="bi bi-arrow-left"></i> Назад к списку
                </a>
                <h1><i class="bi bi-bicycle"></i> Редактировать курьера</h1>
            </div>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="admin-card">
                    <form asp-action="EditCourier" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        
                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label">ФИО</label>
                            <input asp-for="FullName" class="form-control" />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Phone" class="form-label">Телефон</label>
                            <input asp-for="Phone" class="form-control" />
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Status" class="form-label">Статус</label>
                            <select asp-for="Status" class="form-select">
                                <option value="@CourierStatus.Available">Свободен</option>
                                <option value="@CourierStatus.OnDelivery">На доставке</option>
                                <option value="@CourierStatus.Offline">Оффлайн</option>
                            </select>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-lg"></i> Сохранить изменения
                            </button>
                            <a asp-action="Couriers" class="btn btn-outline-secondary">Отмена</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}