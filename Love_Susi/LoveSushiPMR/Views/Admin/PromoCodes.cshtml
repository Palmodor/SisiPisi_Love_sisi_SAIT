@model List<PromoCode>
@{
    ViewData["Title"] = "Промокоды";
}

<section class="admin-section">
    <div class="container-fluid">
        <div class="admin-header">
            <div>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-2">
                    <i class="bi bi-arrow-left"></i> Назад
                </a>
                <h1><i class="bi bi-tag"></i> Промокоды</h1>
            </div>
            <a asp-action="CreatePromoCode" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Добавить промокод
            </a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="admin-card">
            <div class="table-responsive">
                <table class="table admin-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Код</th>
                            <th>Скидка</th>
                            <th>Макс. скидка</th>
                            <th>Мин. сумма</th>
                            <th>Использований</th>
                            <th>Действует до</th>
                            <th>Статус</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var promo in Model)
                        {
                            <tr>
                                <td>@promo.Id</td>
                                <td><span class="badge bg-primary fs-6">@promo.Code</span></td>
                                <td>@promo.DiscountPercent%</td>
                                <td>@(promo.MaxDiscountAmount?.ToString("N0") ?? "-") ₽</td>
                                <td>@(promo.MinOrderAmount?.ToString("N0") ?? "-") ₽</td>
                                <td>@promo.CurrentUsageCount / @(promo.MaxUsageCount?.ToString() ?? "∞")</td>
                                <td>@promo.ValidUntil.ToString("dd.MM.yyyy")</td>
                                <td>
                                    @if (promo.IsActive && promo.ValidUntil >= DateTime.UtcNow)
                                    {
                                        <span class="badge bg-success">Активен</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Неактивен</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="EditPromoCode" asp-route-id="@promo.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil"></i> Редактировать
                                    </a>
                                    <form asp-action="DeletePromoCode" asp-route-id="@promo.Id" method="post" class="d-inline" 
                                          onsubmit="return confirm('Вы уверены, что хотите удалить этот промокод?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i> Удалить
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>