@model List<Promotion>
@{
    ViewData["Title"] = "Акции";
}

<section class="admin-section">
    <div class="container-fluid">
        <div class="admin-header">
            <div>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-2">
                    <i class="bi bi-arrow-left"></i> Назад
                </a>
                <h1><i class="bi bi-megaphone"></i> Акции</h1>
            </div>
            <a asp-action="CreatePromotion" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Добавить акцию
            </a>
        </div>

        <div class="admin-card">
            <div class="table-responsive">
                <table class="table admin-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Изображение</th>
                            <th>Название</th>
                            <th>Описание</th>
                            <th>Скидка</th>
                            <th>Период</th>
                            <th>Статус</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var promo in Model)
                        {
                            <tr>
                                <td>@promo.Id</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(promo.ImageUrl))
                                    {
                                        <img src="@promo.ImageUrl" alt="@promo.Name" class="dish-thumb" />
                                    }
                                    else
                                    {
                                        <span class="dish-thumb-placeholder">🎁</span>
                                    }
                                </td>
                                <td><strong>@promo.Name</strong></td>
                                <td>@promo.Description</td>
                                <td>@(promo.DiscountPercent.HasValue ? $"{promo.DiscountPercent}%" : "-")</td>
                                <td>@promo.StartDate.ToString("dd.MM.yyyy") - @promo.EndDate.ToString("dd.MM.yyyy")</td>
                                <td>
                                    @if (promo.IsActive && promo.EndDate >= DateTime.UtcNow)
                                    {
                                        <span class="badge bg-success">Активна</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Неактивна</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group">
                                        <a asp-action="EditPromotion" asp-route-id="@promo.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="DeletePromotion" asp-route-id="@promo.Id" method="post" 
                                              onsubmit="return confirm('Удалить акцию @promo.Name?');" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>