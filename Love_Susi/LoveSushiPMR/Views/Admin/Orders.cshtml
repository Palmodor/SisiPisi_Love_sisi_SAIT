@model List<OrderManagementViewModel>
@{
    ViewData["Title"] = "Управление заказами";
}

<section class="admin-section">
    <div class="container-fluid">
        <div class="admin-header">
            <div>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-2">
                    <i class="bi bi-arrow-left"></i> Назад
                </a>
                <h1><i class="bi bi-cart"></i> Управление заказами</h1>
            </div>
        </div>

        <!-- Фильтры -->
        <div class="admin-filters mb-4">
            <div class="btn-group">
                <a asp-action="Orders" class="btn btn-outline-primary @(string.IsNullOrEmpty(ViewBag.SelectedStatus) ? "active" : "")">Все</a>
                @if (ViewBag.StatusMappings is System.Collections.Generic.List<dynamic> statusMappings)
                {
                    @foreach (var mapping in statusMappings)
                    {
                        <a asp-action="Orders" asp-route-status="@mapping.EnglishName" 
                           class="btn btn-outline-primary @(ViewBag.SelectedStatus == mapping.EnglishName ? "active" : "")">@mapping.RussianName</a>
                    }
                }
            </div>
        </div>

        <div class="admin-card">
            <div class="table-responsive">
                <table class="table admin-table">
                    <thead>
                        <tr>
                            <th>№ заказа</th>
                            <th>Клиент</th>
                            <th>Телефон</th>
                            <th>Сумма</th>
                            <th>Статус</th>
                            <th>Дата</th>
                            <th>Курьер</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td><strong>@order.OrderNumber</strong></td>
                                <td>@order.CustomerName</td>
                                <td>@order.Phone</td>
                                <td>@order.TotalAmount.ToString("N0") ₽</td>
                                <td>
                                    @{
                                        var statusClass = order.StatusKey?.ToLower() switch
                                        {
                                            "pending" => "bg-warning",
                                            "confirmed" => "bg-info",
                                            "preparing" => "bg-primary",
                                            "readyfordelivery" => "bg-info",
                                            "ondelivery" => "bg-primary",
                                            "delivered" => "bg-success",
                                            "cancelled" => "bg-secondary",
                                            "rejected" => "bg-danger",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @statusClass">@order.CurrentStatus</span>
                                </td>
                                <td>@order.OrderDate.ToString("dd.MM HH:mm")</td>
                                <td>
                                    @if (order.AssignedCourierId.HasValue)
                                    {
                                        <i class="bi bi-check-circle text-success"></i>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="OrderDetails" asp-route-id="@order.Id" class="btn btn-sm btn-primary">
                                        <i class="bi bi-eye"></i> Подробнее
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>