<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LoveSushi PMR</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <span class="brand-icon">🍣</span>
                    <span class="brand-text">LoveSushi</span>
                    <span class="brand-pmr">PMR</span>
                </a>
                
                <div class="header-contacts d-none d-lg-flex">
                    <a href="tel:+37377712345" class="phone-link">
                        <i class="bi bi-telephone-fill"></i>
                        <span>+373 (777) 12-345</span>
                    </a>
                    <span class="work-hours">Ежедневно 10:00-23:00</span>
                </div>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto align-items-center">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Главная</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Menu" asp-action="Index">Меню</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Delivery">Доставка</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Contacts">Контакты</a>
                        </li>
                        
                        <li class="nav-item">
                            <a class="nav-link cart-link" asp-controller="Cart" asp-action="Index">
                                <i class="bi bi-cart3"></i>
                                <span class="cart-badge" id="cart-count">0</span>
                            </a>
                        </li>

                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            @if (User.IsInRole("Администратор"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                        <i class="bi bi-speedometer2"></i> Админ
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Index">Панель управления</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Orders">Заказы</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Dishes">Блюда</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Categories">Категории</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Promotions">Акции</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Users">Пользователи</a></li>
                                    </ul>
                                </li>
                            }
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                    <i class="bi bi-person-circle"></i> @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile">Профиль</a></li>
                                    <li><a class="dropdown-item" asp-controller="Order" asp-action="History">Мои заказы</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                            <button type="submit" class="dropdown-item">Выйти</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm ms-2" asp-controller="Account" asp-action="Login">Войти</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show m-0" role="alert">
                <div class="container">
                    <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show m-0" role="alert">
                <div class="container">
                    <i class="bi bi-exclamation-circle-fill"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="container">
            <div class="row">
                <div class="col-lg-4 mb-4">
                    <div class="footer-brand">
                        <span class="brand-icon">🍣</span>
                        <span class="brand-text">LoveSushi PMR</span>
                    </div>
                    <p class="footer-description">
                        Доставка свежих суши и роллов в Тирасполе и ближайших городах. 
                        Качественные продукты, быстрая доставка, отличный вкус!
                    </p>
                    <div class="social-links">
                        <a href="#"><i class="bi bi-instagram"></i></a>
                        <a href="#"><i class="bi bi-telegram"></i></a>
                        <a href="#"><i class="bi bi-whatsapp"></i></a>
                        <a href="#"><i class="bi bi-vk"></i></a>
                    </div>
                </div>
                <div class="col-lg-2 col-md-6 mb-4">
                    <h5>Меню</h5>
                    <ul class="footer-links">
                        <li><a asp-controller="Menu" asp-action="Index" asp-route-categoryId="1">Суши и роллы</a></li>
                        <li><a asp-controller="Menu" asp-action="Index" asp-route-categoryId="2">Сеты</a></li>
                        <li><a asp-controller="Menu" asp-action="Index" asp-route-categoryId="3">WOK</a></li>
                        <li><a asp-controller="Menu" asp-action="Index" asp-route-categoryId="4">Пицца</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-6 mb-4">
                    <h5>Информация</h5>
                    <ul class="footer-links">
                        <li><a asp-controller="Home" asp-action="About">О нас</a></li>
                        <li><a asp-controller="Home" asp-action="Delivery">Доставка и оплата</a></li>
                        <li><a asp-controller="Home" asp-action="Contacts">Контакты</a></li>
                        <li><a href="#">Акции</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-6 mb-4">
                    <h5>Контакты</h5>
                    <ul class="footer-contacts">
                        <li><i class="bi bi-geo-alt"></i> г. Тирасполь, ул. Ленина, 1</li>
                        <li><a href="tel:+37377712345"><i class="bi bi-telephone"></i> +373 (777) 12-345</a></li>
                        <li><a href="mailto:info@lovesushi.md"><i class="bi bi-envelope"></i> info@lovesushi.md</a></li>
                        <li><i class="bi bi-clock"></i> Ежедневно 10:00-23:00</li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2024 LoveSushi PMR. Все права защищены.</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/additional-methods.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
